rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && role() == 'admin';
    }

    function isProf() {
      return isAuth() && role() == 'professor';
    }

    function isAdminOrProf() {
      return isAdmin() || isProf();
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read: if isAdminOrProf() || isOwner(uid);

      allow create: if isAdmin()
        || (isProf()
          && request.resource.data.role == 'aluno'
          && request.resource.data.active == true)
        || (isOwner(uid)
          && request.resource.data.role == 'pendente'
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.keys().hasOnly(['email','name','photoURL','role','createdAt']));

      allow update: if isAdmin()
        || (isProf() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active']));

      allow delete: if isAdmin();

      match /workouts/{wkId} {
        allow read, write: if isAdminOrProf() || isOwner(uid);
      }

      match /sessions/{sessionId} {
        allow read, write: if isAdminOrProf() || isOwner(uid);
      }
    }

    match /exercises/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrProf();
    }

    match /wk_templates/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrProf();
    }

    // mail/ is written only by Admin SDK (Cloud Functions) — clients have no access
    match /mail/{id} {
      allow read, write: if false;
    }
  }
}
